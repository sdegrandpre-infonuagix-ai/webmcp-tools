{
  "name": "webmcp-evals-cli",
  "version": "0.1.0",
  "description": "A command-line tool to run evals for WebMCP schema definitions",
  "license": "Apache-2.0",
  "type": "module",
  "scripts": {
    "postinstall": "npm install --prefix ui",
    "build": "tsc",
    "test": "tsc && node --test dist/test/*.test.js",
    "serve": "tsc && npm run build --prefix ui && node dist/bin/serve.js",
    "lint": "oxlint",
    "format": "oxfmt --write"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.47",
    "@ai-sdk/google": "^3.0.31",
    "@ai-sdk/openai": "^3.0.33",
    "@google/genai": "^1.38.0",
    "@types/cli-progress": "^3.11.6",
    "@types/minimist": "^1.2.5",
    "ai": "^6.0.98",
    "chalk": "^5.6.2",
    "cli-progress": "^3.12.0",
    "cli-table3": "^0.6.5",
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "minimist": "^1.2.8",
    "ollama": "^0.6.3",
    "open": "^11.0.0",
    "ora": "^9.3.0",
    "puppeteer-core": "^24.37.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.0.10",
    "eslint-plugin-license-header": "^0.9.0",
    "oxfmt": "^0.36.0",
    "oxlint": "^1.51.0",
    "typescript": "^5.9.3"
  }
}
